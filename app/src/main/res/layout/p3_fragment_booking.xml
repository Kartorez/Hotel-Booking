<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="guest"
            type="com.example.hotelbooking.model.Booking" />
    </data>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".practical5.BookingFragment">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F8F9FF"
            android:orientation="vertical">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_card"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="14dp"
                            android:letterSpacing="0.08"
                            android:text="@string/booking_details"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:text="@string/label_check_in"
                            android:textColor="#9E9E9E"
                            android:textSize="11sp" />

                        <EditText
                            android:id="@+id/checkInInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:background="@drawable/bg_input"
                            android:drawableStart="@drawable/baseline_calendar_month_24"
                            android:drawablePadding="10dp"
                            android:drawableTint="#008AC9"
                            android:hint="@string/date_hint"
                            android:inputType="text"
                            android:maxLines="1"
                            android:paddingStart="14dp"
                            android:paddingTop="12dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="12dp"
                            android:text="@={guest.checkInDate}"
                            android:textColor="#1C1B1F"
                            android:textColorHint="#BDBDBD"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:text="@string/label_check_out"
                            android:textColor="#9E9E9E"
                            android:textSize="11sp" />

                        <EditText
                            android:id="@+id/checkOutInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_input"
                            android:drawableStart="@drawable/baseline_event_24"
                            android:drawablePadding="10dp"
                            android:drawableTint="#008AC9"
                            android:hint="@string/date_hint"
                            android:inputType="text"
                            android:maxLines="1"
                            android:paddingStart="14dp"
                            android:paddingTop="12dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="12dp"
                            android:text="@={guest.checkOutDate}"
                            android:textColor="#1C1B1F"
                            android:textColorHint="#BDBDBD"
                            android:textSize="14sp" />

                        <!-- Кількість ночей + ціна за ніч -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="14dp"
                            android:paddingTop="10dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="10dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:contentDescription="@null"
                                app:tint="#008AC9"
                                android:src="@drawable/baseline_calendar_month_24" />

                            <TextView
                                android:id="@+id/textViewNights"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                android:text="Вкажіть дати"
                                android:textColor="#1C1B1F"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/textViewPricePerNight"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₴0/ніч"
                                android:textColor="#008AC9"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/bg_card"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="14dp"
                            android:letterSpacing="0.08"
                            android:text="@string/guest_data"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:text="@string/label_name"
                            android:textColor="#9E9E9E"
                            android:textSize="11sp" />

                        <EditText
                            android:id="@+id/nameInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:background="@drawable/bg_input"
                            android:drawableStart="@drawable/baseline_person_24"
                            android:drawablePadding="10dp"
                            android:drawableTint="#008AC9"
                            android:hint="@string/name_hint"
                            android:inputType="textPersonName"
                            android:maxLines="1"
                            android:paddingStart="14dp"
                            android:paddingTop="12dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="12dp"
                            android:text="@={guest.firstGuestName}"
                            android:textColor="#1C1B1F"
                            android:textColorHint="#BDBDBD"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:text="@string/label_email"
                            android:textColor="#9E9E9E"
                            android:textSize="11sp" />

                        <EditText
                            android:id="@+id/emailInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="10dp"
                            android:background="@drawable/bg_input"
                            android:drawableStart="@drawable/baseline_email_24"
                            android:drawablePadding="10dp"
                            android:drawableTint="#008AC9"
                            android:hint="email@example.com"
                            android:inputType="textEmailAddress"
                            android:maxLines="1"
                            android:paddingStart="14dp"
                            android:paddingTop="12dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="12dp"
                            android:text="@={guest.email}"
                            android:textColor="#1C1B1F"
                            android:textColorHint="#BDBDBD"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:text="@string/label_phone"
                            android:textColor="#9E9E9E"
                            android:textSize="11sp" />

                        <EditText
                            android:id="@+id/phoneInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_input"
                            android:drawableStart="@drawable/baseline_phone_24"
                            android:drawablePadding="10dp"
                            android:drawableTint="#008AC9"
                            android:hint="+380 67 000 0000"
                            android:inputType="phone"
                            android:maxLines="1"
                            android:paddingStart="14dp"
                            android:paddingTop="12dp"
                            android:paddingEnd="14dp"
                            android:paddingBottom="12dp"
                            android:text="@={guest.phone}"
                            android:textColor="#1C1B1F"
                            android:textColorHint="#BDBDBD"
                            android:textSize="14sp" />

                    </LinearLayout>

                </LinearLayout>
            </ScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:elevation="8dp"
                android:orientation="vertical">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/total"
                            android:textColor="#9E9E9E"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/textViewNightsSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 ночей × ₴0"
                            android:textColor="#9E9E9E"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/textViewTotalPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₴0"
                            android:textColor="#008AC9"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonConfirm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="28dp"
                        android:paddingVertical="14dp"
                        android:text="@string/button_confirm"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        app:backgroundTint="#008AC9"
                        app:cornerRadius="28dp" />

                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </FrameLayout>
</layout>