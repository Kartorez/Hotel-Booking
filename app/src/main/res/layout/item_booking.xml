<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>
        <variable
            name="hotel"
            type="com.example.hotelbooking.model.Hotel" />
        <variable
            name="booking"
            type="com.example.hotelbooking.model.Booking" />
    </data>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp">

            <ImageView
                android:id="@+id/HotelImage"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_room_icon"
                android:scaleType="centerCrop"
                android:src="@{hotel.imageRes}"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/infoBlock"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="@+id/HotelImage"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/HotelImage"
                app:layout_constraintTop_toTopOf="@id/HotelImage">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@{hotel.name}"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Panorama Grand" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:drawableStart="@drawable/baseline_location_on_24"
                    android:drawableTint="#008AC9"
                    android:text='@{hotel.address + ", " + hotel.city}'
                    android:textColor="#49454F"
                    android:textSize="13sp"
                    tools:text="вул. Хрещатик, 1, Київ" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:drawableStart="@drawable/baseline_calendar_month_24"
                    android:drawablePadding="4dp"
                    android:drawableTint="#008AC9"
                    android:text="@{booking.checkInDate + ` - ` + booking.checkOutDate}"
                    android:textColor="#008AC9"
                    android:textSize="12sp"
                    tools:text="01.04.2026 - 05.05.2026" />

            </LinearLayout>

            <TextView
                android:id="@+id/textViewStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/rounded_bg"
                android:padding="6dp"
                android:text="@{booking.status}"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/HotelImage"
                tools:text="Активне" />

            <TextView
                android:id="@+id/textViewPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text='@{"₴" + booking.totalPrice}'
                android:textColor="#1A6EBF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBaseline_toBaselineOf="@id/textViewStatus" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonCancel"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="8dp"
                android:text="Скасувати"
                android:textColor="#FF0000"
                app:backgroundTint="#FFFFFF"
                app:cornerRadius="100dp"
                app:layout_constraintEnd_toStartOf="@id/buttonDetails"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/textViewStatus"
                app:rippleColor="#33FF0000"
                app:strokeColor="#FF0000"
                app:strokeWidth="1dp" />

            <Button
                android:id="@+id/buttonDetails"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#2F6FED"
                android:text="Деталі"
                android:textColor="#FFF"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/buttonCancel"
                app:layout_constraintTop_toTopOf="@id/buttonCancel" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</layout>